{
  "name": "better-toast-workspace",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:website": "ng build website --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:better-toast": "ng test better-toast --no-watch",
    "serve:ssr:website": "node dist/website/server/server.mjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/common": "^21.2.13",
    "@angular/compiler": "^21.2.13",
    "@angular/core": "^21.2.13",
    "@angular/forms": "^21.2.13",
    "@angular/platform-browser": "^21.2.13",
    "@angular/platform-server": "^21.2.13",
    "@angular/router": "^21.2.13",
    "@angular/ssr": "^21.2.12",
    "@lucide/angular": "^1.8.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@vercel/analytics": "^2.0.1",
    "better-drawer": "^0.0.1",
    "express": "^5.1.0",
    "highlight.js": "^11.11.1",
    "postcss": "^8.5.9",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.2.2",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.12",
    "@angular/cli": "^21.2.12",
    "@angular/compiler-cli": "^21.2.13",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
